auto-install-peers=true
strict-peer-dependencies=false
@jsr:registry=https://npm.jsr.io
# Private competitor-prices plugin lives on GitHub Packages (GHCR npm). The token
# is injected from the GHCR_NPM_TOKEN env var (a read:packages secret in CI /
# Docker build); never commit it. The @machinagod/moloni-client-ts dep is aliased
# to @jsr above, so it is unaffected by this scope registry.
@machinagod:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GHCR_NPM_TOKEN}
